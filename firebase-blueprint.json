{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "batch": { "type": "string", "description": "Student batch designation" },
        "approvedCourseIds": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of course IDs the student is officially enrolled and approved in."
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Quiz": {
      "title": "ACE-CPT Quiz",
      "description": "A quiz containing multiple MCQs for a specific chapter or topic, or a Google Form link.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "chapter": { "type": "string", "description": "Chapter number or range (e.g., '1', '1-5')" },
        "courseId": { "type": "string", "description": "ID of the associated course" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "pointsPerQuestion": { "type": "integer" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "type": { "type": "string", "enum": ["ai", "google_form"], "description": "Type of quiz: AI-generated or Google Form." },
        "googleFormUrl": { "type": "string", "format": "uri" },
        "assignedTo": { "type": "array", "items": { "type": "string" }, "description": "List of student UIDs assigned to this quiz." },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "integer" },
              "explanation": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "createdAt", "status", "type", "createdBy"]
    },
    "Score": {
      "title": "Student Score",
      "description": "Records a student's performance on a quiz.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "quizId": { "type": "string" },
        "quizTitle": { "type": "string" },
        "courseId": { "type": "string", "description": "ID of the associated course" },
        "score": { "type": "integer" },
        "totalQuestions": { "type": "integer" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "quizId", "score", "totalQuestions", "completedAt"]
    },
    "Material": {
      "title": "Study Material",
      "description": "Chapter notes or other study resources.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "chapter": { "type": "string" },
        "courseId": { "type": "string", "description": "ID of the associated course" },
        "type": { "type": "string", "enum": ["pdf", "drive"], "description": "Type of material: PDF upload or Google Drive link." },
        "fileUrl": { "type": "string", "description": "URL to the PDF file or base64 data." },
        "driveUrl": { "type": "string", "format": "uri", "description": "Link to Google Drive folder or file." },
        "assignedTo": { "type": "array", "items": { "type": "string" }, "description": "List of student UIDs assigned to this material." },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "type", "createdAt", "createdBy"]
    },
    "LiveClass": {
      "title": "Live Class",
      "description": "Information about live classes and their recordings.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "courseId": { "type": "string", "description": "ID of the associated course" },
        "link": { "type": "string", "format": "uri" },
        "recordingLink": { "type": "string", "format": "uri" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "array", "items": { "type": "string" }, "description": "List of student UIDs assigned to this class." },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "link", "createdAt", "createdBy"]
    },
    "Inquiry": {
      "title": "Course Inquiry",
      "description": "Inquiries from students about specific courses.",
      "type": "object",
      "properties": {
        "studentEmail": { "type": "string", "format": "email" },
        "studentMobile": { "type": "string" },
        "courseName": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentEmail", "studentMobile", "courseName", "createdAt"]
    },
    "SuccessStory": {
      "title": "Success Story",
      "description": "Student testimonials and success stories with video links.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "student": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" },
        "videoUrl": { "type": "string", "format": "uri" },
        "order": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "student", "thumbnail", "videoUrl", "createdAt"]
    },
    "FlashcardSet": {
      "title": "Flashcard Set",
      "description": "A set of flashcards for a specific chapter or topic.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "chapter": { "type": "string" },
        "courseId": { "type": "string", "description": "ID of the associated course" },
        "cards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "front": { "type": "string" },
              "back": { "type": "string" }
            },
            "required": ["front", "back"]
          }
        },
        "assignedTo": { "type": "array", "items": { "type": "string" }, "description": "List of student UIDs assigned to this set." },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "cards", "createdAt", "createdBy"]
    },
    "Exercise": {
      "title": "Exercise",
      "description": "An exercise video tutorial for the digital library.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "description": "e.g., 'Lower Body', 'Core'" },
        "videoUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "videoUrl", "createdAt"]
    },
    "KnowledgeVideo": {
      "title": "Knowledge Sharing Video",
      "description": "Informative videos on fitness, sports, health, and nutrition.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["Fitness", "Sports", "Health", "Nutrition"] },
        "videoUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "videoUrl", "createdAt"]
    },
    "Announcement": {
      "title": "Admin Announcement",
      "description": "Important messages or tasks from admin to students.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "task", "urgent"] },
        "courseId": { "type": "string", "description": "Optional: target course" },
        "batch": { "type": "string", "description": "Optional: target batch" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "content", "type", "createdAt", "createdBy"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Messages for 2-way communication between students and admin.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "The UID of the student involved in the chat." },
        "senderId": { "type": "string", "description": "The UID of the message sender." },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "senderId", "text", "createdAt"]
    },
    "Course": {
      "title": "Course",
      "description": "A curriculum or program.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "totalQuizzes": { "type": "integer", "description": "Total number of question papers/quizzes for this course to calculate progress." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "createdAt"]
    },
    "Feedback": {
      "title": "Module Feedback",
      "description": "Student feedback on a specific chapter.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "chapter": { "type": "string" },
        "understandingRating": { "type": "number", "minimum": 1, "maximum": 5 },
        "teachingRating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "courseId", "chapter", "createdAt"]
    },
    "ClassRecording": {
      "title": "Class Recording",
      "description": "Recorded sessions of past classes.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "chapter": { "type": "string" },
        "courseId": { "type": "string", "description": "ID of the associated course" },
        "videoUrl": { "type": "string", "format": "uri" },
        "assignedTo": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "videoUrl", "courseId", "createdAt", "createdBy"]
    },
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracking completion of course content for students.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "courseId": { "type": "string" },
        "completedItems": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "IDs of completed materials, recordings, or quizzes"
        },
        "lastAccessedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "courseId", "completedItems"]
    },
    "Notification": {
      "title": "System Notification",
      "description": "Alerts for admin about student activities.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["new_student", "new_inquiry", "quiz_completed"] },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentEmail": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "createdAt", "read"]
    },
    "ActivityLog": {
      "title": "Admin Activity Log",
      "description": "Records modifications made by admins for auditing.",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminName": { "type": "string" },
        "action": { "type": "string" },
        "targetType": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adminId", "adminName", "action", "createdAt"]
    }
  },
  "firestore": {
    "/activityLogs/{logId}": {
      "schema": "ActivityLog",
      "description": "Historical log of admin actions recorded for auditing."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of system notifications for the admin."
    },
    "/userProgress/{progressId}": {
      "schema": "UserProgress",
      "description": "Collection of student progress per course."
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Collection of available courses."
    },
    "/classRecordings/{recordingId}": {
      "schema": "ClassRecording",
      "description": "Collection of recorded class sessions."
    },
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of student chapter feedback."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Collection of available quizzes."
    },
    "/scores/{scoreId}": {
      "schema": "Score",
      "description": "Student quiz results."
    },
    "/materials/{materialId}": {
      "schema": "Material",
      "description": "Collection of study materials."
    },
    "/liveClasses/{classId}": {
      "schema": "LiveClass",
      "description": "Collection of live classes."
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Student course inquiries."
    },
    "/successStories/{storyId}": {
      "schema": "SuccessStory",
      "description": "Student success stories for the landing page."
    },
    "/flashcards/{setId}": {
      "schema": "FlashcardSet",
      "description": "Collection of chapter flashcards."
    },
    "/exercises/{exerciseId}": {
      "schema": "Exercise",
      "description": "Exercise library videos."
    },
    "/knowledgeVideos/{videoId}": {
      "schema": "KnowledgeVideo",
      "description": "Knowledge sharing videos."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Admin announcements."
    },
    "/chatMessages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages between students and admin."
    }
  }
}
